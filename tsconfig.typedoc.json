{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "isolatedDeclarations": false,
    "noEmit": true,
    "paths": {
      "@gh-gantt/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": ["packages/shared/src/**/*.ts", "packages/cli/src/**/*.ts"],
