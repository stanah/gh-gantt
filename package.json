{
  "name": "gh-gantt",
  "version": "0.2.1-alpha",
  "private": true,
  "description": "GitHub Projects Gantt chart with hierarchical progress tracking",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev & gh-gantt serve --api-only & wait",
    "lint": "git ls-files -z -- . ':(exclude)CHANGELOG.md' ':(exclude)packages/*/CHANGELOG.md' | xargs -0 vp check",
    "test": "pnpm test:workflow && pnpm -r test",
    "test:workflow": "vp test run tests/**/*.test.ts",
    "test:workflow:json": "vp test run tests/**/*.test.ts --reporter=default --reporter=json --outputFile=test-results-workflow.json",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:json": "pnpm test:workflow:json && pnpm -r test:json",
    "typecheck": "pnpm -r typecheck",
    "smoke:personal": "pnpm --filter @gh-gantt/smoke smoke:personal",
    "smoke:org": "pnpm --filter @gh-gantt/smoke smoke:org",
    "docs:gen": "tsx scripts/docs-gen.ts",
    "req:trace": "tsx scripts/req-trace.ts",
    "req:validate": "tsx scripts/req-validate.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@gh-gantt/shared": "workspace:*",
    "@playwright/test": "^1.58.2",
    "lefthook": "^2.1.4",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "vite-plus": "^0.1.24",
    "vitest": "4.1.8",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ],
    "overrides": {
      "esbuild": "0.28.1",
      "fast-uri": "3.1.2",
      "path-to-regexp": "0.1.13",
      "qs": "6.15.2",
      "vite": "8.0.16",
      "ws": "8.21.0",
      "brace-expansion": "5.0.6"
    }
  }
}
