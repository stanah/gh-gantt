{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "gh-gantt dev-role review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issueNumber",
    "pass",
    "verdict",
    "scoreBreakdown",
    "findings",
    "reviewedFiles",
    "rubricPath",
    "verifyResultPath"
  ],
  "properties": {
    "issueNumber": {
      "type": "integer",
      "minimum": 1
    },
    "pass": {
      "type": "integer",
      "minimum": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "comment", "request-changes", "block"]
    },
    "scoreBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirementsAlignment", "testEvidence", "maintainability", "safety"],
      "properties": {
        "requirementsAlignment": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "testEvidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "maintainability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "safety": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "location", "issue", "suggestion"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "nit"]
          },
          "location": {
            "type": "string",
            "minLength": 1
          },
          "issue": {
            "type": "string",
            "minLength": 1
          },
          "suggestion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reviewedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rubricPath": {
      "type": "string",
      "minLength": 1
    },
    "verifyResultPath": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verdict": {
            "enum": ["request-changes", "block"]
          }
        }
      },
      "then": {
        "properties": {
          "findings": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
